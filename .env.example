# ============================================
# VARIABLES D'ENVIRONNEMENT POUR DOKPLOY
# ============================================
# Copiez ce fichier et configurez les valeurs dans Dokploy

# === BASE DE DONNÉES POSTGRESQL ===
POSTGRES_DB=audace_db
POSTGRES_USER=audace_user
POSTGRES_PASSWORD=VotreMotDePasseTresSecurise123!
POSTGRES_PORT=5432

# === JWT & SÉCURITÉ ===
# Générez une clé secrète forte avec: openssl rand -hex 32
SECRET_KEY=votre_cle_secrete_tres_longue_et_aleatoire_ici_minimum_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === CONFIGURATION EMAIL ===
# Pour l'envoi d'emails (reset password, etc.)
MAIL_USERNAME=votre.email@gmail.com
MAIL_PASSWORD=votre_mot_de_passe_application
MAIL_FROM=noreply@audace.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Audace API
MAIL_TLS=true
MAIL_SSL=false

# === URLS DE L'APPLICATION ===
FRONTEND_URL=https://votre-frontend.com
BACKEND_URL=https://api.votre-domaine.com
API_PORT=8000

# === ENVIRONNEMENT ===
ENVIRONMENT=production
DEBUG=false
WORKERS=4

# === UTILISATEUR ADMIN PAR DÉFAUT ===
# Ces credentials sont utilisés pour créer automatiquement un admin au premier démarrage
# ⚠️ IMPORTANT: Changez ces valeurs en production pour plus de sécurité!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2024!
ADMIN_EMAIL=admin@audace.local
ADMIN_NAME=Administrateur
ADMIN_FAMILY_NAME=Système

# === OVH API ===
# Pour consulter vos services OVH depuis le SaaS
# Créez une application sur https://eu.api.ovh.com/createApp/
# Puis générez un consumer_key avec droits GET uniquement
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=votre_application_key
OVH_APPLICATION_SECRET=votre_application_secret
OVH_CONSUMER_KEY=votre_consumer_key

# === SCALEWAY DEDIBOX API ===
SCW_SECRET_KEY=votre_token_scaleway

# === SOCIAL OAUTH (Facebook, Instagram, LinkedIn, Twitter) ===
# Facebook / Instagram (meme Meta App)
# Creez une app sur https://developers.facebook.com/
FACEBOOK_APP_ID=votre_facebook_app_id
FACEBOOK_APP_SECRET=votre_facebook_app_secret
FACEBOOK_CONFIG_ID=votre_config_id_login_for_business

# LinkedIn
# Creez une app sur https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=votre_linkedin_client_id
LINKEDIN_CLIENT_SECRET=votre_linkedin_client_secret

# Twitter/X
# Creez une app sur https://developer.twitter.com/
TWITTER_CLIENT_ID=votre_twitter_client_id
TWITTER_CLIENT_SECRET=votre_twitter_client_secret

# ============================================
# NOTES IMPORTANTES:
# ============================================
# 1. POSTGRES_PASSWORD: Utilisez un mot de passe fort
# 2. SECRET_KEY: Générez avec: openssl rand -hex 32
# 3. MAIL_PASSWORD: Pour Gmail, utilisez un "mot de passe d'application"
#    (Compte Google > Sécurité > Validation en 2 étapes > Mots de passe des applications)
# 4. FRONTEND_URL & BACKEND_URL: Mettez vos vrais domaines
# 5. Ne committez JAMAIS le fichier .env avec les vraies valeurs!